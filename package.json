{
  "name": "jermainevault",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces run build",
    "dev": "concurrently \"yarn workspace @jermainevault/api dev\" \"yarn workspace @jermainevault/web dev\"",
    "lint": "yarn workspaces run lint",
    "test": "yarn workspaces run test",
    "typecheck": "yarn workspaces run typecheck"
  },
  "devDependencies": {
    "concurrently": "5.3.0",
    "typescript": "4.1.6"
  }
}
