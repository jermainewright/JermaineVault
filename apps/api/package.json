    "@types/bcryptjs": "2.4.2",
    "@types/cors": "2.8.8",
    "@types/express": "4.17.9",
    "@types/jsonwebtoken": "8.5.0",
    "@types/node": "14.14.9",
    "@types/uuid": "8.3.0",
    "eslint": "7.14.0",
    "jest": "26.6.3",
